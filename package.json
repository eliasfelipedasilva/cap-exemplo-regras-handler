{
    "name": "cap-exemplo",
    "version": "1.0.0",
    "description": "A simple CAP project.",
    "repository": "<Add your repository here>",
    "license": "UNLICENSED",
    "private": true,
    "dependencies": {
        "@cap-js/hana": "^2",
        "@cap-js/sqlite": "*",
        "@sap/cds": "^9.8.0",
        "express": "^4"
    },
    "devDependencies": {
        "@cap-js/cds-test": "*",
        "jest": "^29"
    },
    "scripts": {
        "start": "cds run",
        "watch": "cds watch",
        "build": "cds build --production",
        "deploy": "mbt build -t ./ && cf deploy cap-exemplo_1.0.0.mtar --delete-service-keys",
        "deploy:cf": "cf push",
        "undeploy": "cf undeploy cap-exemplo --delete-services --delete-service-keys",
        "test": "jest --testTimeout=60000",
        "test:watch": "jest --watch --testTimeout=60000"
    },
    "eslintConfig": {
        "extends": "eslint:recommended",
        "env": {
            "es2020": true,
            "node": true,
            "jest": true,
            "mocha": true
        },
        "globals": {
            "SELECT": true,
            "INSERT": true,
            "UPDATE": true,
            "DELETE": true,
            "CREATE": true,
            "DROP": true,
            "CDL": true,
            "CQL": true,
            "CXL": true,
            "cds": true
        },
        "rules": {
            "no-console": "off",
            "require-atomic-updates": "off"
        }
    },
    "cds": {
        "requires": {
            "db": {
                "[development]": {
                    "kind": "sqlite"
                },
                "[production]": {
                    "kind": "hanatrial"
                }
            }
        },
        "build": {
            "tasks": [
                {
                    "for": "hana",
                    "src": "db",
                    "options": {
                        "model": [
                            "db",
                            "srv"
                        ]
                    }
                },
                {
                    "for": "nodejs",
                    "src": "srv"
                }
            ]
        },
        "hana": {
            "deploy-format": "hdbtable"
        }
    }
}